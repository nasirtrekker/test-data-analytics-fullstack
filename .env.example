# Example environment variables - Copy to .env and customize
# DO NOT commit .env files with real values!

# Application Settings
APP_DATA_PATH=./sample_videos.csv
APP_RANDOM_STATE=42
APP_CLUSTER_K=2
APP_ANOMALY_CONTAMINATION=0.05
APP_TEST_SIZE=0.2
APP_ALPHA=0.1

# Environment
ENVIRONMENT=development
DEBUG=true

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1

# Frontend Configuration
VITE_API_URL=http://localhost:8000

# MLflow (Production only)
# MLFLOW_TRACKING_URI=http://mlflow:5000
# MLFLOW_EXPERIMENT_NAME=content-insights

# Database (Production only)
# POSTGRES_USER=mlflow
# POSTGRES_PASSWORD=changeme_in_production
# POSTGRES_DB=mlflow
# POSTGRES_HOST=mlflow-db
# POSTGRES_PORT=5432

# Security (Production only)
# SECRET_KEY=generate_random_secret_key_for_jwt
# CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com
# ALLOWED_HOSTS=yourdomain.com,api.yourdomain.com

# Monitoring (Production only)
# SENTRY_DSN=https://your-sentry-dsn
# LOG_LEVEL=INFO
